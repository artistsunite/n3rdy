# Rename this file to .env.local and fill in your values.

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com/
# Set Authorised redirect URI to: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# N3RDY Bot API URL (where your FastAPI bot is running)
NEXT_PUBLIC_BOT_API_URL=http://localhost:8000
